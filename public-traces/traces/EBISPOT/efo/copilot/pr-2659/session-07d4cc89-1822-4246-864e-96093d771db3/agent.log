Bash: Test SPARQL to get UniProt IDs from is_about -> protein -> annotation axiom xrefs
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot merge --   
  catalog catalog-v001.xml --input efo-edit.owl query --select /dev/stdin     
  /tmp/is_about_uniprot.tsv 2>&1 <<'SPARQL'                                   
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    SELECT DISTINCT ?term ?term_label ?uniprot_id                             
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> .             
      ?term rdfs:subClassOf ?restr .                                          
      ?restr owl:onProperty obo:IAO_0000136 ;                                 
             owl:someValuesFrom ?protein .                                    
      FILTER(isIRI(?protein))                                                 
      # Get UniProtKB xrefs from annotation axioms on the protein's definition
      ?axiom owl:annotatedSource ?protein ;                                   
             oio:hasDbXref ?uniprot_id .                                      
      FILTER(STRSTARTS(?uniprot_id, "UniProtKB:"))                            
      OPTIONAL { ?term rdfs:label ?term_label . }                             
      FILTER(isIRI(?term))                                                    
    }                                                                         
    ORDER BY ?uniprot_id ?term_label                                          
    SPARQL                                                                    
    echo "---"                                                                
    wc -l /tmp/is_about_uniprot.tsv                                           
    head -25 /tmp/is_about_uniprot.tsv                                        
    ---                                                                       
