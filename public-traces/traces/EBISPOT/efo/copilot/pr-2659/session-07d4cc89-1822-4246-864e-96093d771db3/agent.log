Bash: Test SPARQL to find measurement terms with is_about -> protein -> UniProtKB xref
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot query --use-
  graphs true --catalog catalog-v001.xml --input efo-edit.owl --select        
  /dev/stdin /dev/stdout 2>/dev/null <<'SPARQL'                               
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    SELECT DISTINCT ?term ?term_label ?uniprot_id                             
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> ;             
        rdfs:subClassOf [ rdf:type owl:Restriction ;                          
                          owl:onProperty obo:IAO_0000136 ;                    
                          owl:someValuesFrom ?protein ] .                     
      ?protein oio:hasDbXref ?uniprot_id .                                    
      OPTIONAL { ?term rdfs:label ?term_label . }                             
      FILTER(isIRI(?term))                                                    
      FILTER(STRSTARTS(?uniprot_id, "UniProtKB:"))                            
    }                                                                         
    LIMIT 10                                                                  
    SPARQL                                                                    
    org.semanticweb.owlapi.model.UnloadableImportException: Could not load    
  imported ontology: <http://www.ebi.ac.uk/efo/imports/mondo_import.owl>      
