$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot merge --   
  catalog catalog-v001.xml --input efo-edit.owl query --select /dev/stdin     
  /tmp/oba_is_about.tsv 2>&1 <<'SPARQL'                                       
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    SELECT DISTINCT ?term ?term_label ?protein ?protein_label ?uniprot_id     
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> .             
      FILTER(STRSTARTS(STR(?term), "http://purl.obolibrary.org/obo/OBA_"))    
      ?term rdfs:subClassOf ?restr .                                          
      ?restr owl:onProperty obo:IAO_0000136 ;                                 
             owl:someValuesFrom ?protein .                                    
      FILTER(isIRI(?protein))                                                 
      # Get UniProtKB xrefs from annotation axioms                            
      OPTIONAL {                                                              
        ?axiom owl:annotatedSource ?protein ;                                 
               oio:hasDbXref ?uniprot_id .                                    
        FILTER(STRSTARTS(?uniprot_id, "UniProtKB:"))                          
      }                                                                       
      OPTIONAL { ?term rdfs:label ?term_label . }                             
      OPTIONAL { ?protein rdfs:label ?protein_label . }                       
      FILTER(isIRI(?term))                                                    
    }                                                                         
    ORDER BY ?term_label                                                      
    LIMIT 30                                                                  
    SPARQL                                                                    
    echo "---"                                                                
    wc -l /tmp/oba_is_about.tsv                                               
    head -30 /tmp/oba_is_about.tsv                                            
    ---                                                                       
    0 /tmp/oba_is_about.tsv                                                   
    <exited with exit code 0>

