    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    SELECT DISTINCT ?term ?term_label ?protein ?uniprot_id                    
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> .             
      ?term rdfs:subClassOf ?restr .                                          
      ?restr owl:onProperty obo:IAO_0000136 ;                                 
             owl:someValuesFrom ?protein .                                    
      FILTER(isIRI(?protein))                                                 
      FILTER(STRSTARTS(STR(?protein), "http://purl.obolibrary.org/obo/PR_"))  
      OPTIONAL { ?term rdfs:label ?term_label . }                             
      OPTIONAL { ?protein oio:hasDbXref ?uniprot_id .                         
  FILTER(STRSTARTS(?uniprot_id, "UniProtKB:")) }                              
      FILTER(isIRI(?term))                                                    
    }                                                                         
    ORDER BY ?term                                                            
    LIMIT 20                                                                  
    SPARQL                                                                    
    echo "---"                                                                
    wc -l /tmp/is_about_test2.tsv                                             
    head -20 /tmp/is_about_test2.tsv                                          
    ---                                                                       
