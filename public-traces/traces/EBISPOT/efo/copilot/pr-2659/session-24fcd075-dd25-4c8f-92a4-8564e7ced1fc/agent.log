This works. Now let me run the full query without limit to see the total    
  count:

Bash: Run full query for all human PR resolutions
$ cd /home/runner/work/efo/efo/src/ontology && cat > /tmp/test-human-pr-  
  full.sparql << 'EOF'                                                        
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    SELECT DISTINCT ?term ?term_label ?uniprot_id                             
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> ;             
        rdfs:subClassOf [ owl:onProperty obo:IAO_0000136 ;                    
                          owl:someValuesFrom ?protein ] .                     
      FILTER(isIRI(?term))                                                    
      FILTER(STRSTARTS(STR(?protein), "http://purl.obolibrary.org/obo/PR_"))  
      # Find human-specific subclass of the protein                           
      ?human_protein rdfs:subClassOf ?protein ;                               
        rdfs:subClassOf [ owl:onProperty obo:RO_0002160 ;                     
                          owl:someValuesFrom obo:NCBITaxon_9606 ] .           
      # Get UniProtKB xref from annotation axiom on human protein             
      ?axiom owl:annotatedSource ?human_protein ;                             
             oio:hasDbXref ?raw_id .                                          
      FILTER(STRSTARTS(?raw_id, "UniProtKB:"))                                
      BIND(CONCAT("uniprot:", REPLACE(?raw_id, "^UniProtKB:", "")) AS         
  ?uniprot_id)                                                                
      OPTIONAL { ?term rdfs:label ?term_label . }                             
    }                                                                         
    ORDER BY ?uniprot_id ?term_label                                          
    EOF                                                                       
    ../../bin/robot query --use-graphs true --catalog catalog-v001.xml --input
  efo-edit.owl --select /tmp/test-human-pr-full.sparql /tmp/human-pr-full.tsv 
  2>&1 | tail -5                                                              
                                                                              
    <exited with exit code 0>

