Bash: Check all namespaces that is_about targets point to
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot query --use-
  graphs true --catalog catalog-v001.xml --input efo-edit.owl --query         
  /dev/stdin /dev/stdout <<'EOF'                                              
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    # Check all the different protein namespaces that is_about points to      
    SELECT ?prefix (COUNT(DISTINCT ?term) AS ?count)                          
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> ;             
        rdfs:subClassOf [ owl:onProperty obo:IAO_0000136 ;                    
                          owl:someValuesFrom ?protein ] .                     
      FILTER(isIRI(?term))                                                    
      FILTER(isIRI(?protein))                                                 
      BIND(REPLACE(STR(?protein), "/[^/]*$", "/") AS ?prefix)                 
    }                                                                         
    GROUP BY ?prefix                                                          
    ORDER BY DESC(?count)                                                     
    EOF                                                                       
    prefix,count                                                              
    http://purl.obolibrary.org/obo/,4024                                      
    http://www.ebi.ac.uk/efo/,196                                             
    http://www.orpha.net/ORDO/,1                                              
    <exited with exit code 0>

