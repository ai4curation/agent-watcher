Bash: Compare direct vs annotation axiom UniProtKB xrefs on human PR proteins
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot query --use-
  graphs true --catalog catalog-v001.xml --input efo-edit.owl --query         
  /dev/stdin /dev/stdout <<'EOF'                                              
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    # Count human PR proteins found via direct hasDbXref vs annotation axiom  
    SELECT                                                                    
      (COUNT(DISTINCT ?direct_id) AS ?direct_count)                           
      (COUNT(DISTINCT ?axiom_id) AS ?axiom_count)                             
    WHERE {                                                                   
      ?human_protein rdfs:subClassOf [ owl:onProperty obo:RO_0002160 ;        
                                        owl:someValuesFrom obo:NCBITaxon_9606 
  ] .                                                                         
      FILTER(STRSTARTS(STR(?human_protein), "http://purl.obolibrary.          
  org/obo/PR_"))                                                              
      OPTIONAL {                                                              
        ?human_protein oio:hasDbXref ?direct_id .                             
        FILTER(STRSTARTS(?direct_id, "UniProtKB:"))                           
      }                                                                       
      OPTIONAL {                                                              
        ?axiom owl:annotatedSource ?human_protein ;                           
               oio:hasDbXref ?axiom_id .                                      
        FILTER(STRSTARTS(?axiom_id, "UniProtKB:"))                            
      }                                                                       
    }                                                                         
    EOF                                                                       
    direct_count,axiom_count                                                  
    6412,6389                                                                 
    <exited with exit code 0>

