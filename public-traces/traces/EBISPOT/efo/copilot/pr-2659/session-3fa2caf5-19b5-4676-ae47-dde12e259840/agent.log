Bash: Check which protein namespaces provide UniProtKB in is_about path
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot query --use-
  graphs true --catalog catalog-v001.xml --input efo-edit.owl --query         
  /dev/stdin /dev/stdout <<'EOF'                                              
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    # Check the is_about -> direct UniProtKB path - which protein namespaces  
  are involved?                                                               
    SELECT ?ns (COUNT(*) AS ?cnt)                                             
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> ;             
        rdfs:subClassOf [ owl:onProperty obo:IAO_0000136 ;                    
                          owl:someValuesFrom ?protein ] .                     
      ?axiom owl:annotatedSource ?protein ;                                   
             oio:hasDbXref ?raw_id .                                          
      FILTER(STRSTARTS(?raw_id, "UniProtKB:"))                                
      FILTER(isIRI(?term))                                                    
      BIND(REPLACE(STR(?protein), "^(http://[^/]+/[^/]+/)([A-Za-z]+_).*",     
  "$2") AS ?ns)                                                               
    }                                                                         
    GROUP BY ?ns                                                              
    ORDER BY DESC(?cnt)                                                       
    EOF                                                                       
    ns,cnt                                                                    
    PR_,81                                                                    
    <exited with exit code 0>


