Bash: Find all non-standard uniprot xref prefix patterns on measurement terms
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot query --use-
  graphs true --catalog catalog-v001.xml --input efo-edit.owl --query         
  /dev/stdin /dev/stdout <<'EOF'                                              
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    # Find ALL UniProt-related hasDbXref across ALL measurement or obsolete   
  terms                                                                       
    # that don't start with uniprot: or UniProtKB:                            
    SELECT DISTINCT ?xref_prefix (COUNT(*) AS ?cnt)                           
    WHERE {                                                                   
      {                                                                       
        ?term rdf:type owl:Class ;                                            
          rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> ;           
          oio:hasDbXref ?xref .                                               
        FILTER(isIRI(?term))                                                  
        FILTER(REGEX(?xref, "[Uu]ni[Pp]rot", "i"))                            
        FILTER(!STRSTARTS(?xref, "uniprot:"))                                 
        BIND(REPLACE(?xref, "^([^:]+:|https?://[^/]+/[^/]+/).*", "$1") AS     
  ?xref_prefix)                                                               
      }                                                                       
    }                                                                         
    GROUP BY ?xref_prefix                                                     
    ORDER BY DESC(?cnt)                                                       
    EOF                                                                       
    xref_prefix,cnt                                                           
    https:,2                                                                  
    <exited with exit code 0>

