Bash: Check if EFO-namespace is_about targets have UniProt xrefs
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot query --use-
  graphs true --catalog catalog-v001.xml --input efo-edit.owl --query         
  /dev/stdin /dev/stdout <<'EOF'                                              
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    # Check if any EFO-namespace is_about targets have UniProt xrefs          
    SELECT ?term ?term_label ?protein ?prot_label ?xref                       
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> ;             
        rdfs:subClassOf [ owl:onProperty obo:IAO_0000136 ;                    
                          owl:someValuesFrom ?protein ] .                     
      FILTER(isIRI(?term))                                                    
      FILTER(STRSTARTS(STR(?protein), "http://www.ebi.ac.uk/efo/"))           
      ?protein oio:hasDbXref ?xref .                                          
      FILTER(REGEX(?xref, "[Uu]ni[Pp]rot", "i"))                              
      OPTIONAL { ?term rdfs:label ?term_label . }                             
      OPTIONAL { ?protein rdfs:label ?prot_label . }                          
    }                                                                         
    LIMIT 20                                                                  
    EOF                                                                       
                                                                              
    <exited with exit code 0>

