Bash: Find measurement terms with non-standard UniProt xref formats
$ cd /home/runner/work/efo/efo/src/ontology && ../../bin/robot query --use-
  graphs true --catalog catalog-v001.xml --input efo-edit.owl --query         
  /dev/stdin /dev/stdout <<'EOF'                                              
    prefix oio: <http://www.geneontology.org/formats/oboInOwl#>               
    prefix owl: <http://www.w3.org/2002/07/owl#>                              
    prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>                      
    prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>                 
    prefix obo: <http://purl.obolibrary.org/obo/>                             
                                                                              
    SELECT DISTINCT ?term ?term_label ?xref                                   
    WHERE {                                                                   
      ?term rdf:type owl:Class ;                                              
        rdfs:subClassOf+ <http://www.ebi.ac.uk/efo/EFO_0001444> ;             
        oio:hasDbXref ?xref .                                                 
      OPTIONAL { ?term rdfs:label ?term_label . }                             
      FILTER(isIRI(?term))                                                    
      FILTER(REGEX(?xref, "^(UniProt:|UniProtKB:|https?://.*uniprot)", "i"))  
    }                                                                         
    ORDER BY ?xref                                                            
