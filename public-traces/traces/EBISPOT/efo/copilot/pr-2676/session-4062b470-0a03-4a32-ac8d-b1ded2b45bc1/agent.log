    matches = re.findall(pattern, content, re.DOTALL)                         
                                                                              
    parents = {}                                                              
    for iri, body in matches:                                                 
        subclassof = re.findall(r'rdfs:subClassOf rdf:resource=\"([^\"]+)\"', 
