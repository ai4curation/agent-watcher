Bash: Find EFO class with label blood group
$ cd /home/runner/work/efo/efo && python3 -c "                            
    import re                                                                 
    with open('src/ontology/efo-edit.owl') as f:                              
        content = f.read()                                                    
                                                                              
    # Find term with label 'blood group'                                      
    # Search for the pattern                                                  
    for m in re.finditer(r'(<owl:Class rdf:about=\"[^\"]+                     
  \">(?:(?!</owl:Class>).)*?<rdfs:label[^>]*>blood group</rdfs:label>)',      
  content, re.DOTALL):                                                        
        # Get the IRI from the rdf:about                                      
        iri_m = re.search(r'rdf:about=\"([^\"]+)\"', m.group())               
        if iri_m:                                                             
            print('Found:', iri_m.group(1))                                   
    " 2>/dev/null                                                             
