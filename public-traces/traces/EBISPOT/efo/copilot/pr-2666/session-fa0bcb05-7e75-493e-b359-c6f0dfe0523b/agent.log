  the host genome, resulting in transient transgene expression that is lost   
  upon cell division.",                                                       
            "parent": "http://www.ebi.ac.uk/efo/EFO_0920065",                 
            "organizational_class": True,                                     
            "pmids": ["41746105", "41624053"],                                
            "synonyms": [],                                                   
        },                                                                    
        {                                                                     
