  viral mechanisms of cell entry and genome delivery.",                       
            "parent": "http://www.ebi.ac.uk/efo/EFO_0920064",                 
            "organizational_class": True,                                     
            "pmids": ["41494593", "41593732"],                                
            "synonyms": [],                                                   
        },                                                                    
        {                                                                     
            "id": "EFO_0920066",                                              
