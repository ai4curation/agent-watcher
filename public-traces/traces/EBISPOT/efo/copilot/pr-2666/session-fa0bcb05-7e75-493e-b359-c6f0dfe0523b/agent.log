    DATE = "2026-03-26T11:30:00Z"                                             
    BASE_EFO = "http://www.ebi.ac.uk/efo/"                                    
                                                                              
    def syn_tag(syn_type, value):                                             
        tag_map = {                                                           
            "exact": "oboInOwl:hasExactSynonym",                              
            "related": "oboInOwl:hasRelatedSynonym",                          
            "narrow": "oboInOwl:hasNarrowSynonym",                            
            "broad": "oboInOwl:hasBroadSynonym",                              
        }                                                                     
        tag = tag_map[syn_type]                                               
        return f"        <{tag}>{value}</{tag}>"                              
                                                                              
    def make_term(t):                                                         
        lines = []                                                            
        iri = f"http://www.ebi.ac.uk/efo/{t['id']}"                           
        lines.append(f"\n\n    <!-- {iri} -->\n")                             
        lines.append(f"    <owl:Class rdf:about=\"{iri}\">")                  
        lines.append(f"        <rdfs:subClassOf                               
  rdf:resource=\"{t['parent']}\"/>")                                          
        lines.append(f"                                                       
  <obo:IAO_0000115>{t['definition']}</obo:IAO_0000115>")                      
        lines.append(f"        <obo:IAO_0000117>AI agent</obo:IAO_0000117>")  
        lines.append(f"        <dc:date rdf:datatype=\"http://www.w3.         
  org/2001/XMLSchema#dateTime\">{DATE}</dc:date>")                            
        if t.get("organizational_class"):                                     
            lines.append(f"                                                   
  <efo:organizational_class>true</efo:organizational_class>")                 
        for syn_type, syn_val in t.get("synonyms", []):                       
            lines.append(syn_tag(syn_type, syn_val))                          
        lines.append(f"        <rdfs:label                                    
  xml:lang=\"en\">{t['label']}</rdfs:label>")                                 
        lines.append(f"    </owl:Class>")                                     
        lines.append(f"    <owl:Axiom>")                                      
        lines.append(f"        <owl:annotatedSource rdf:resource=\"{iri}\"/>")
        lines.append(f"        <owl:annotatedProperty                         
  rdf:resource=\"http://purl.obolibrary.org/obo/IAO_0000115\"/>")             
        lines.append(f"                                                       
  <owl:annotatedTarget>{t['definition']}</owl:annotatedTarget>")              
        for pmid in t['pmids']:                                               
            lines.append(f"                                                   
  <oboInOwl:hasDbXref>PMID:{pmid}</oboInOwl:hasDbXref>")                      
        lines.append(f"    </owl:Axiom>")                                     
        return "\n".join(lines)                                               
                                                                              
    output = ""                                                               
    for t in terms:                                                           
        output += make_term(t)                                                
    output += "\n"                                                            
                                                                              
    print(output)                                                             
