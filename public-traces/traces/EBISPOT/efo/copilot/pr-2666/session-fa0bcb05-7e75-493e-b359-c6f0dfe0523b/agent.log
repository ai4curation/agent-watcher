            "pmids": ["41800026", "41593679"],                                
            "synonyms": [],                                                   
        },                                                                    
        {                                                                     
            "id": "EFO_0920067",                                              
            "label": "lentivirus transduction",                               
            "definition": "A stable viral transduction method that uses       
