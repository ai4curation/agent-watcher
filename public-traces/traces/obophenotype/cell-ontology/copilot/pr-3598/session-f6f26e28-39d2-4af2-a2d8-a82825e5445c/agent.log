Bash: View acinar cell of salivary gland term
$ cd /home/runner/work/cell-ontology/cell-ontology && sed -n '20510,      
  20525p' src/ontology/cl-edit.owl                                            
    # Class: obo:CL_0002623 (acinar cell of salivary gland)                   
                                                                              
    AnnotationAssertion(Annotation(oboInOwl:hasDbXref "GOC:tfm")              
  Annotation(oboInOwl:hasDbXref "PMID:24646566") Annotation(oboInOwl:hasDbXref
  "PMID:25843887") Annotation(oboInOwl:hasDbXref "PMID:28623666")             
  Annotation(oboInOwl:hasDbXref "PMID:34989394") Annotation(oboInOwl:hasDbXref
  "PMID:35343828") obo:IAO_0000115 obo:CL_0002623 "An acinar cell that is part
  of the salivary gland epithelium, responsible for synthesizing and secreting
  the primary saliva essential for oral digestion, antimicrobial defense, and 
  mucosal immunity. It features apical-basal polarity with apical secretory   
  granules, and tight junctions that maintain polarity and regulate calcium-  
  dependent saliva exocytosis triggered by parasympathetic and sympathetic    
  signals (Ambudkar, 2015). This cell functions in coordination with          
  contractile myoepithelial cells, which aid saliva flow through the ducts    
  into the oral cavity (Khan et al., 2022). In mice and humans, acinar cell   
  development relies on the transcription factor SOX2 (Emmerson et al., 2017),
  with self-renewal achieved primarily through acinar cell self-duplication   
  and supported by progenitor populations during injury and regeneration (Aure
  et al., 2016).")                                                            
    AnnotationAssertion(terms:contributor obo:CL_0002623 <https://orcid.      
  org/0000-0003-1980-3228>)                                                   
    AnnotationAssertion(oboInOwl:creation_date obo:CL_0002623 "2011-03-       
  14T02:22:22Z"^^xsd:dateTime)                                                
    AnnotationAssertion(Annotation(oboInOwl:hasDbXref "PMID:24646566")        
  oboInOwl:hasExactSynonym obo:CL_0002623 "salivary acinar cell")             
    AnnotationAssertion(Annotation(oboInOwl:hasDbXref "PMID:24646566")        
