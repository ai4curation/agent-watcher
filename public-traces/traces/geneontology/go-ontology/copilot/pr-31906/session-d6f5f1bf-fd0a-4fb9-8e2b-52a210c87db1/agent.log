Bash: Apply targeted parent and definition updates in go-edit.obo
$ python - <<'PY'                                                         
    from pathlib import Path                                                  
    path=Path('/home/runner/work/go-ontology/go-ontology/src/ontology/go-edit.
  obo')                                                                       
    text=path.read_text()                                                     
    blocks=text.split('\n\n')                                                 
    move_ids={                                                                
     'GO:0140443','GO:0160183','GO:0160190','GO:0160204','GO:0160214',        
  'GO:0170009','GO:0180050'                                                   
    }                                                                         
    updated=[]                                                                
    for i,b in enumerate(blocks):                                             
        lines=b.splitlines()                                                  
        tid=None                                                              
        for ln in lines:                                                      
            if ln.startswith('id: GO:'):                                      
                tid=ln.split('id: ')[1].strip(); break                        
        if tid in move_ids:                                                   
            new=[]                                                            
            changed=False                                                     
            for ln in lines:                                                  
                if ln=='is_a: GO:0043495 ! protein-membrane adaptor activity':
                    ln='is_a: GO:0140177 ! membrane-membrane adaptor activity'
                    changed=True                                              
                new.append(ln)                                                
            if changed:                                                       
                updated.append((tid,'parent'))                                
            lines=new                                                         
        if tid=='GO:0160190':                                                 
            new=[]                                                            
            changed=False                                                     
            old='def: "The binding activity of a molecule that brings together
  the peroxisome and the mitochondrial outer membrane, establishing the       
  localization of the peroxisome close to the mitochondrion." [PMID:29720625, 
  PMID:38669296]'                                                             
            rep='def: "The binding activity of a molecule that brings together
  the peroxisome membrane and the mitochondrial outer membrane, establishing  
  the localization of the peroxisome close to the mitochondrion."             
  [PMID:29720625, PMID:38669296]'                                             
            for ln in lines:                                                  
                if ln==old:                                                   
                    ln=rep                                                    
                    changed=True                                              
                new.append(ln)                                                
            if changed:                                                       
                updated.append((tid,'definition'))                            
            lines=new                                                         
        blocks[i]='\n'.join(lines)                                            
    new_text='\n\n'.join(blocks)                                              
    if new_text!=text:                                                        
        path.write_text(new_text)                                             
    print('Updated:', updated)                                                
